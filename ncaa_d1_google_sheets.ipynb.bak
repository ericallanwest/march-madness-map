{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 1. Import Libraries\n",
    "Load spatial libraries to run the Voronoi generation and mapping."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "095ccab0",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import geopandas as gpd\n",
    "from shapely.ops import voronoi_diagram\n",
    "from shapely.geometry import MultiPoint\n",
    "import io\n",
    "import warnings\n",
    "\n",
    "warnings.filterwarnings('ignore')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "7130ebac",
   "metadata": {},
   "source": [
    "### 2. Load the Live Data from Google Sheets\n",
    "This pulls the dataset containing all 362 teams. You can update `Furthest_Round` dynamically in your Google Sheet, and immediately rerun this notebook to see the updated maps!"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "0b970a80",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Downloading active teams from Google Sheets...\n",
      "Loaded 365 teams from your live Google Sheet!\n"
     ]
    }
   ],
   "source": [
    "# IMPORTANT: Replace this placeholder ID with your newly created Google Sheet's ID.\n",
    "# Ensure the Google Sheet is set to \"Anyone with the link can view\" -> Viewer.\n",
    "\n",
    "sheet_id = \"1dZO435DeLvW9RfHgLL_eko2gfbK4MPUR669L5qBxFkU\"\n",
    "sheet_url = f\"https://docs.google.com/spreadsheets/d/{sheet_id}/export?format=csv\"\n",
    "print(f\"Downloading active teams from Google Sheets...\")\n",
    "\n",
    "try:\n",
    "    all_teams_df = pd.read_csv(sheet_url)\n",
    "    print(f\"Loaded {len(all_teams_df)} teams from your live Google Sheet!\")\n",
    "except Exception as e:\n",
    "    print(f\"Error loading Google Sheet. Did you set `Anyone with the link can view`?\\nError: {e}\")\n",
    "    print(\"\\nFalling back to local generated CSV (`ncaa_d1_teams_initial.csv`)...\")\n",
    "    try:\n",
    "        all_teams_df = pd.read_csv(\"ncaa_d1_teams_initial.csv\")\n",
    "        print(f\"Loaded {len(all_teams_df)} teams from local fallback CSV instead.\")\n",
    "    except FileNotFoundError:\n",
    "        print(\"Local CSV also not found. Please run the `scraper.py` script first to generate the dataset!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f676bbbf",
   "metadata": {},
   "source": [
    "### 3. Load the US Boundary\n",
    "Read a US States GeoJSON directly from a web URL, dissolve the state borders into a single national polygon, and clip it to the contiguous lower 48 states."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "d8e70102",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Fetching 50-State US Boundary from the web...\n",
      "50-State Boundary ready!\n"
     ]
    }
   ],
   "source": [
    "print(\"Fetching 50-State US Boundary from the web...\")\n",
    "\n",
    "full_us_epsg = 3857 \n",
    "\n",
    "url = \"https://raw.githubusercontent.com/PublicaMundi/MappingAPI/master/data/geojson/us-states.json\"\n",
    "states = gpd.read_file(url)\n",
    "\n",
    "states = states[(states['id'] != '72') & (states['id'] != '02')]\n",
    "us_full = states.dissolve()\n",
    "us_boundary = us_full.to_crs(epsg=full_us_epsg).buffer(1500) # Buffer 1.5km to protect coastal islands\n",
    "\n",
    "print(\"50-State Boundary ready!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "cc5e5ffe",
   "metadata": {},
   "source": [
    "### 4. The Smart Voronoi GeoJSON Generator\n",
    "This dynamically draws the territories, clips them cleanly to the US boundary, and exports a lightweight map file for any active iteration round. It now embeds ALL column data into the features."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "f5b7b89a",
   "metadata": {},
   "outputs": [],
   "source": [
    "import math\n",
    "\n",
    "def export_round_geojson(target_round):\n",
    "    print(f\"Processing Round of {target_round}...\")\n",
    "    \n",
    "    active_teams = all_teams_df[all_teams_df['Furthest_Round'] <= target_round].copy()\n",
    "    if active_teams.empty:\n",
    "        print(f\"Skipping Round {target_round} - no active teams found.\")\n",
    "        return\n",
    "        \n",
    "    active_teams.reset_index(drop=True, inplace=True)\n",
    "    \n",
    "    teams_gdf = gpd.GeoDataFrame(\n",
    "        active_teams, \n",
    "        geometry=gpd.points_from_xy(active_teams.Lon, active_teams.Lat), \n",
    "        crs=\"EPSG:4326\"\n",
    "    ).to_crs(epsg=full_us_epsg)\n",
    "\n",
    "    # Handle edge case where there is only 1 team left (the champion won't make a valid Voronoi)\n",
    "    if len(teams_gdf) == 1:\n",
    "        final_territories = us_boundary.copy()\n",
    "        for col in active_teams.columns:\n",
    "            final_territories[col] = active_teams[col].iloc[0]\n",
    "    else:\n",
    "        team_points = MultiPoint(teams_gdf.geometry.values)\n",
    "        voronoi_polys = voronoi_diagram(team_points, envelope=us_boundary.unary_union.envelope)\n",
    "        voronoi_gdf = gpd.GeoDataFrame(geometry=list(voronoi_polys.geoms), crs=full_us_epsg)\n",
    "\n",
    "        # Pass ALL loaded Google sheet columns into the map file dynamically\n",
    "        territories = gpd.sjoin(\n",
    "            voronoi_gdf, \n",
    "            teams_gdf, \n",
    "            how='inner', \n",
    "            predicate='intersects'\n",
    "        )\n",
    "        final_territories = gpd.clip(territories, us_boundary)\n",
    "        \n",
    "    final_territories = final_territories.reset_index(drop=True)\n",
    "    # Note: Simplify logic smoothed border lines to lower file size, but some gaps can occur.\n",
    "    final_territories['geometry'] = final_territories['geometry'].simplify(500)\n",
    "    final_territories = final_territories.to_crs(epsg=4326)\n",
    "    \n",
    "    filename = f\"round_{target_round}.geojson\"\n",
    "    final_territories.to_file(filename, driver=\"GeoJSON\")\n",
    "    print(f\"Saved {filename} with 50 states!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "afae32d3",
   "metadata": {},
   "source": [
    "### 5. Execute Pipeline\n",
    "Automatically generate geojson maps for all rounds currently detected in your Google Sheet."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "030ee348",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Processing Round of 362...\n",
      "Saved round_362.geojson with 50 states!\n",
      "Processing Round of 68...\n",
      "Saved round_68.geojson with 50 states!\n",
      "Processing Round of 64...\n",
      "Saved round_64.geojson with 50 states!\n",
      "Processing Round of 32...\n",
      "Saved round_32.geojson with 50 states!\n",
      "Processing Round of 16...\n",
      "Saved round_16.geojson with 50 states!\n",
      "Processing Round of 8...\n",
      "Saved round_8.geojson with 50 states!\n",
      "Processing Round of 4...\n",
      "Saved round_4.geojson with 50 states!\n",
      "Processing Round of 2...\n",
      "Saved round_2.geojson with 50 states!\n",
      "\n",
      "All perfect Voronoi maps generated successfully based on your Google Sheet data!\n"
     ]
    }
   ],
   "source": [
    "# Find all unique rounds currently present in the dataset (e.g. 362, 68, 64...)\n",
    "try:\n",
    "    rounds_to_generate = sorted([int(r) for r in all_teams_df['Furthest_Round'].dropna().unique()], reverse=True)\n",
    "    \n",
    "    for r in rounds_to_generate:\n",
    "        export_round_geojson(r)\n",
    "        \n",
    "    print(\"\\nAll perfect Voronoi maps generated successfully based on your Google Sheet data!\")\n",
    "except NameError:\n",
    "    print(\"Error: all_teams_df not found. Please run cell 2 above to load your data.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "d5d80aff",
   "metadata": {},
   "source": [
